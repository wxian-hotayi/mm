# ─────────────────────────────────────────────────────────────────────────────
# WealthOS — DEVELOPMENT environment template.
# Copy to `.env` (gitignored) and adjust. `config.py` reads `.env` from the repo
# root AND from backend/. NEVER commit a real `.env`. See docs/DEPLOYMENT.md.
# ─────────────────────────────────────────────────────────────────────────────

# development | production
#   production => Secure cookies are set AND a weak/placeholder SECRET_KEY is rejected.
ENV=development

# 64+ random chars. Generate:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# The placeholder below is REJECTED at startup when ENV=production.
SECRET_KEY=change-me-generate-64-random-chars

# SQLite (default, dev). For PostgreSQL use:
#   postgresql+asyncpg://USER:PASSWORD@HOST:5432/wealthos
# (Postgres requires adding `asyncpg` to backend/requirements.txt — see DEPLOYMENT.md.)
DATABASE_URL=sqlite+aiosqlite:///./data/wealthos.db

# Browser origin allowed by CORS with credentials. Dev Vite server:
FRONTEND_ORIGIN=http://localhost:5173

# Seed admin — used ONLY on first run against an empty DB. REQUIRED when ENV=production.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong

# Session lifetimes.
ACCESS_TOKEN_MINUTES=30
REFRESH_DAYS_REMEMBER=30
REFRESH_DAYS_DEFAULT=1

# In-memory sliding-window rate limiting (keep true in staging/production).
RATE_LIMIT_ENABLED=true

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# OpenAI — NOT used yet (roadmap Phase 6). Leave blank.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
