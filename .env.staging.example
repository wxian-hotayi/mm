# ─────────────────────────────────────────────────────────────────────────────
# WealthOS — STAGING environment template.
# Staging MIRRORS production hardening so issues surface before launch.
# Copy to `.env` on the staging host (or set via the platform secret store).
# Set ENV=production so Secure cookies + strict SECRET_KEY validation apply.
# ─────────────────────────────────────────────────────────────────────────────

ENV=production

# Unique, NOT shared with production. 64+ random chars.
SECRET_KEY=__set_a_unique_64_char_random_value_for_staging__

# SQLite on a PERSISTENT volume (absolute path => 4 slashes), or managed Postgres.
DATABASE_URL=sqlite+aiosqlite:////data/wealthos.db
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/wealthos

# Exact HTTPS origin the browser loads the app from.
FRONTEND_ORIGIN=https://staging.wealthos.example

# Seed admin (first run only). Use staging-only credentials; change after first login.
ADMIN_EMAIL=you+staging@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__strong_unique_staging_password__

ACCESS_TOKEN_MINUTES=30
REFRESH_DAYS_REMEMBER=30
REFRESH_DAYS_DEFAULT=1
RATE_LIMIT_ENABLED=true
LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
