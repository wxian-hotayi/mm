# ─────────────────────────────────────────────────────────────────────────────
# WealthOS — PRODUCTION environment template.
# Manage these via your platform's SECRET store (Render/Fly/Railway/etc.) —
# do NOT commit a populated file. ENV=production enables Secure cookies and
# rejects weak/placeholder secrets at startup. See docs/DEPLOYMENT.md.
# ─────────────────────────────────────────────────────────────────────────────

ENV=production

# REQUIRED. Unique, 64+ random chars. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this value invalidates all issued JWT access tokens (forces re-login).
SECRET_KEY=__REQUIRED_unique_64_char_random_value__

# SQLite on a PERSISTENT volume (absolute path => 4 slashes), OR managed Postgres.
# Postgres requires adding `asyncpg` to backend/requirements.txt.
DATABASE_URL=sqlite+aiosqlite:////data/wealthos.db
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/wealthos

# Exact HTTPS origin the browser loads the app from (CORS allow-list).
# With a same-origin proxy/rewrite (recommended) CORS is not exercised, but set it correctly.
FRONTEND_ORIGIN=https://app.wealthos.example

# Seed admin — REQUIRED on first run (startup aborts in production if missing).
# Change the password immediately after first login.
ADMIN_EMAIL=owner@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__REQUIRED_strong_unique_password__

# Shorter access token => smaller post-logout JWT validity window.
ACCESS_TOKEN_MINUTES=30
REFRESH_DAYS_REMEMBER=30
REFRESH_DAYS_DEFAULT=1

# Keep rate limiting ON. NOTE: in-memory + per-process — run a SINGLE worker/instance
# (see DEPLOYMENT.md) or move to a shared store before scaling out.
RATE_LIMIT_ENABLED=true

LOG_LEVEL=INFO

# Roadmap (Phase 6) — leave blank until AI features ship.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Future SMTP (NOT yet implemented — design only, see DEPLOYMENT.md §5) ──
# Reserved, provider-agnostic names for when password-reset email delivery lands:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM="WealthOS <no-reply@wealthos.example>"
# SMTP_STARTTLS=true
